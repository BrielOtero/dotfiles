    name = Gabriel
    signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIPrsIy/mXamzCPeLQEHL+h7kJBzUM7saG2DpdwzarYe1
[init]
    defaultBranch = main
[filter "lfs"]
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
[commit]
    gpgsign = true

[include]
    path = "/home/id/.config/git/gitconfig"

