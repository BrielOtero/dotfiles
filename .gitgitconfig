[user]
    email = info.otero.gabriel@gmail.com
    name = Gabriel
[init]
    defaultBranch = main
[filter "lfs"]
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
[commit]
    gpgsign = true

[include]
    path = "$HOME/.config/git/macos/gitconfig"
[include]
    path = "$HOME/.config/git/linux/gitconfig"
